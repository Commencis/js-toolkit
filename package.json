{
  "name": "@commencis/js-toolkit",
  "description": "Commencis JavaScript Toolkit for Coding Standards",
  "keywords": [
    "commencis",
    "javascript",
    "typescript",
    "toolkit",
    "config",
    "coding-standards",
    "style-guide",
    "lint",
    "eslint",
    "prettier",
    "stylelint",
    "commitlint"
  ],
  "private": true,
  "author": "Commencis WEB Team",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=24.18"
  },
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint:types": "turbo run lint:types",
    "lint:types:root": "tsc --noEmit",
    "lint:js": "eslint .",
    "lint:js:fix": "eslint . --fix",
    "lint:js:inspect": "npx @eslint/config-inspector@latest",
    "lint:format": "prettier . --check",
    "lint:format:fix": "prettier . --write --list-different",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "test:coverage": "vitest run --coverage",
    "changeset": "changeset",
    "version": "changeset version && pnpm install --no-frozen-lockfile",
    "release": "pnpm run build && changeset publish",
    "ci:review": "turbo run lint test build",
    "precommit": "lint-staged",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@commencis/commitlint-config": "3.4.0",
    "@commencis/eslint-config": "3.6.0",
    "@commencis/lint-staged-config": "3.1.1",
    "@commencis/prettier-config": "3.2.0",
    "@commencis/ts-config": "1.0.0",
    "@commitlint/cli": "21.2.1",
    "@types/node": "24.13.3",
    "@vitest/coverage-v8": "4.1.10",
    "changesets-changelog-clean": "1.4.0",
    "eslint": "10.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "prettier": "3.9.5",
    "tsdown": "0.22.4",
    "turbo": "2.10.4",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
